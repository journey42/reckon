[Unit]
Description=Reckon Service
Requires=docker.service
After=docker.service

[Service]
Environment="DOMAIN=reckon-dev.eastus.cloudapp.azure.com"
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/home/reckon/reckon
ExecStart=/usr/bin/docker-compose up -d
ExecStop=/usr/bin/docker-compose down
TimeoutStartSec=0

[Install]
WantedBy=multi-user.target